{
  "name": "simple-manga-viewer",
  "version": "1.0.3",
  "description": "A simple cross-platform manga/comic viewer",
  "author": "kfnzero",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.simple-manga-viewer.app",
    "productName": "Simple Manga Viewer",
    "afterPack": "./build-scripts/afterPack.js",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "icons/**/*"
    ],
    "fileAssociations": [
      {
        "ext": [
          "jpg",
          "jpeg",
          "png",
          "gif",
          "bmp",
          "webp",
          "tiff",
          "tif",
          "avif"
        ],
        "name": "Image File",
        "description": "Open with Simple Manga Viewer",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/icon.png",
      "signAndEditExecutable": false,
      "executableName": "Simple Manga Viewer"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "rcedit": "^4.0.1"
  }
}
